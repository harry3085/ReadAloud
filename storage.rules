rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── AI 녹음숙제 (Phase 5, 5.5) ───────────────────────────
    // 경로 예: recordings/genTests/{testId}/{uid}/r{n}_{ts}.{webm|m4a}
    match /recordings/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024
                   && request.resource.contentType.matches('audio/.*');
    }

    // ── 학원장 숙제 파일 (PDF / Office / 이미지 / 텍스트만 허용) ───
    // 영상/zip/실행파일 등 학원 외 용도 차단 (Storage 악용 방지, 2026-05-02)
    // 단일 파일 한도 20 MB (이전 50 MB 에서 축소)
    match /hwFiles/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024
                   && (
                     request.resource.contentType == 'application/pdf'
                     || request.resource.contentType.matches('application/vnd\\.openxmlformats-officedocument\\..*')
                     || request.resource.contentType == 'application/msword'
                     || request.resource.contentType == 'application/vnd.ms-excel'
                     || request.resource.contentType == 'application/vnd.ms-powerpoint'
                     || request.resource.contentType.matches('application/.*hwp.*')
                     || request.resource.contentType.matches('image/.*')
                     || request.resource.contentType.matches('text/.*')
                     || request.resource.contentType == 'application/vnd.hancom.hwp'
                   );
    }

    // ── 학원 브랜딩 로고 (academies/{id}/logos/) ───────────────
    // 화이트라벨 — 학원장이 자기 학원 PNG 로고 업로드 (192/512 자동 리사이즈는 서버에서)
    // 읽기: 모두 (학생 앱·학원장 앱·super 앱·PWA manifest fetch)
    // 쓰기: server admin SDK 만 (uploadLogo.js — 클라 직접 쓰기 차단)
    match /academies/{academyId}/logos/{file} {
      allow read: if true;
      allow write: if false;
    }

    // ── LexiAI 기본 브랜딩 로고 (super_admin 만 갱신) ────────────
    // appConfig/branding 도큐먼트와 한 쌍. Free 플랜 학원·미설정 상태의 fallback.
    match /appConfig/branding/logos/{file} {
      allow read: if true;
      allow write: if false;
    }

    // ── 공지 첨부 (현재 미사용이지만 미래 보강) ──────────────
    match /notices/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024
                   && (
                     request.resource.contentType == 'application/pdf'
                     || request.resource.contentType.matches('application/vnd\\.openxmlformats-officedocument\\..*')
                     || request.resource.contentType == 'application/msword'
                     || request.resource.contentType == 'application/vnd.ms-excel'
                     || request.resource.contentType.matches('application/.*hwp.*')
                     || request.resource.contentType.matches('image/.*')
                     || request.resource.contentType.matches('text/.*')
                   );
    }

    // ── 기타 ─────────────────────────────────────────────────
    // 로그인 사용자 읽기 허용, 쓰기는 명시된 경로만
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
