rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // 관리자 판별 — Custom Claims 우선, 미주입 토큰은 기존 get() 폴백
    // 폴백은 멀티테넌시 전환기(Phase 0~2)의 하위 호환용.
    // Phase 2 완료(모든 세션이 claims 수신) 후 get() 분기 제거 예정.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.role == 'academy_admin' ||
        request.auth.token.role == 'super_admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // 슈퍼 어드민 — 전체 학원 관리 권한 (Custom Claims 전용, 폴백 없음)
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── 사용자 ───────────────────────────────────────────────
    // read: 로그인 사용자만 (학생 랭킹·관리자 전체 조회용)
    // pre-auth username 조회는 usernameLookup 컬렉션을 통해 처리 (B3 완료)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    // ── 그룹 ────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── 단원 (단어장) ────────────────────────────────────────
    match /units/{unitId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── 점수 ────────────────────────────────────────────────
    match /scores/{scoreId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── 공지사항 ─────────────────────────────────────────────
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── 숙제 파일 ────────────────────────────────────────────
    match /hwFiles/{fileId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── 사용자 알림 ──────────────────────────────────────────
    match /userNotifications/{notifId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAdmin();
      allow update: if isOwner(resource.data.uid);
      allow delete: if isAdmin();
    }

    // ── FCM 토큰 ─────────────────────────────────────────────
    match /fcmTokens/{userId} {
      allow read: if isAdmin();
      allow write: if isOwner(userId);
    }

    // ── 결제 (관리자 전용) ───────────────────────────────────
    match /payments/{paymentId} {
      allow read, write: if isAdmin();
    }

    // ── 저장된 푸시 목록 (관리자 전용) ──────────────────────
    match /savedPushList/{pushId} {
      allow read, write: if isAdmin();
    }

    // ── 교재 ─────────────────────────────────────────────
    match /books/{bookId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /units/{unitId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    // ── 교재 폴더 ─────────────────────────────────────────
    match /folders/{folderId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── 푸시 알림 목록 (관리자 전용) ─────────────────────
    match /pushNotifications/{pushId} {
      allow read, write: if isAdmin();
    }

    // ── Generator (관리자 전용) ───────────────────────────
    match /genBooks/{id} {
      allow read, write: if isAdmin();
    }
    match /genChapters/{id} {
      allow read, write: if isAdmin();
    }
    match /genPages/{id} {
      allow read, write: if isAdmin();
    }

    // ── AI 문제 세트 (관리자 전용) ────────────────────────
    match /genQuestionSets/{id} {
      allow read, write: if isAdmin();
    }

    // ── AI 정리 프리셋 (관리자 전용) ──────────────────────
    match /genCleanupPresets/{id} {
      allow read, write: if isAdmin();
    }

    // ── API 호출 카운터 (Gemini 사용량 추적) ───────────────
    // read: 관리자만 (위젯 표시용)
    // write: 로그인 사용자 (학생 앱에서 check-recording 호출 후 증가)
    // delete 금지 (감사 흔적 유지)
    match /apiUsage/{day} {
      allow read: if isAdmin();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ── AI 시험 배정 (관리자 작성, 학생 읽기) ─────────────
    match /genTests/{testId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      // 학생별 응시 완료 기록
      match /userCompleted/{userId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId);
        allow delete: if isAdmin();
      }
    }

    // ────────────────────────────────────────────────────────
    //   멀티테넌시 신규 컬렉션 (Phase 0 전환)
    // ────────────────────────────────────────────────────────

    // 플랜 정의 (lite/standard/pro)
    // read: 모든 로그인 사용자 (클라이언트가 기능 게이팅용으로 읽음)
    // write: super_admin 전용 (현재는 로컬 스크립트 admin SDK 로만 수정)
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // 학원 문서
    // read: 모든 로그인 사용자 (현재 default 학원뿐이라 격리 불필요)
    //       Phase 2 에서 academyId 필터로 축소 예정
    // write: super_admin 전용
    match /academies/{academyId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // username → (uid, email) 매핑 (로그인 전 조회 필수)
    // read: 전체 공개 (단, 정확한 {academyId}_{usernameLower} 문서 ID 알아야 접근 가능)
    // create/update/delete: 관리자 (saveStudent / 학생삭제 클라이언트 호출 허용)
    // 서버 API(api/createStudent, api/deleteUser)는 Admin SDK 라 Rules 우회
    match /usernameLookup/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
