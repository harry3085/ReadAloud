rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── 사용자 ───────────────────────────────────────────────
    // 로그인 전 username 조회가 필요해 read는 허용 (향후 usernameLookup 컬렉션으로 분리 예정)
    match /users/{userId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    // ── 그룹 ────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── 단원 (단어장) ────────────────────────────────────────
    match /units/{unitId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── 시험 ────────────────────────────────────────────────
    match /tests/{testId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /userCompleted/{userId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId);
        allow delete: if isAdmin();
      }
    }

    // ── 점수 ────────────────────────────────────────────────
    match /scores/{scoreId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── 공지사항 ─────────────────────────────────────────────
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── 숙제 파일 ────────────────────────────────────────────
    match /hwFiles/{fileId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── 녹음 숙제 ────────────────────────────────────────────
    match /recHw/{hwId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── 녹음 제출 ────────────────────────────────────────────
    match /recSubmissions/{subId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── 사용자 알림 ──────────────────────────────────────────
    match /userNotifications/{notifId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAdmin();
      allow update: if isOwner(resource.data.uid);
      allow delete: if isAdmin();
    }

    // ── FCM 토큰 ─────────────────────────────────────────────
    match /fcmTokens/{userId} {
      allow read: if isAdmin();
      allow write: if isOwner(userId);
    }

    // ── 결제 (관리자 전용) ───────────────────────────────────
    match /payments/{paymentId} {
      allow read, write: if isAdmin();
    }

    // ── 저장된 푸시 목록 (관리자 전용) ──────────────────────
    match /savedPushList/{pushId} {
      allow read, write: if isAdmin();
    }
  }
}
