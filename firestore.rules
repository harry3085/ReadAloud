rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // 관리자 판별 — Custom Claims 우선, 미주입 토큰은 기존 get() 폴백
    // 폴백은 멀티테넌시 전환기(Phase 0~2)의 하위 호환용.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.role == 'academy_admin' ||
        request.auth.token.role == 'super_admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // 슈퍼 어드민 — 전체 학원 관리 권한 (Custom Claims 전용, 폴백 없음)
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── 멀티테넌시 헬퍼 (Phase 4-5) ────────────────────────────
    // 호출자의 academyId (Custom Claims 기반)
    function myAcademyId() {
      return request.auth.token.academyId;
    }

    // 기존 문서가 호출자 학원에 속하는가 (read/update/delete 용)
    // super_admin 은 모든 학원 접근 허용
    function isMyAcademy() {
      return isSuperAdmin() ||
        (isSignedIn() && resource.data.academyId == myAcademyId());
    }

    // 신규 문서가 호출자 학원으로 생성되는가 (create 용)
    function isCreatingForMyAcademy() {
      return isSuperAdmin() ||
        (isSignedIn() && request.resource.data.academyId == myAcademyId());
    }

    // 자기 학원 관리자 (academy_admin + 자기 학원) — read/update/delete
    function isAdminOfMyAcademy() {
      return isAdmin() && isMyAcademy();
    }

    // 자기 학원에 새 문서 만드는 관리자 — create
    function isAdminCreatingForMyAcademy() {
      return isAdmin() && isCreatingForMyAcademy();
    }

    // ── 사용자 ───────────────────────────────────────────────
    // read: 로그인 사용자 (학생 랭킹·관리자 전체 조회용 — 클라가 academyId 로 필터링)
    //       향후 자기 학원만 보도록 강화 가능 (단, 모든 클라이언트 쿼리에 academyId 필터 강제 필요)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    // ── 그룹 ────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isSignedIn() && (isSuperAdmin() || resource.data.academyId == myAcademyId());
      allow create: if isAdminCreatingForMyAcademy();
      allow update, delete: if isAdminOfMyAcademy();
    }

    // ── 점수 ────────────────────────────────────────────────
    // 학생: 같은 학원 모든 점수 read 가능 (랭킹 화면 — 클라이언트가 group 필터로 같은 반만 표시)
    // 관리자: 자기 학원 점수만 read/update/delete
    match /scores/{scoreId} {
      allow read: if isSignedIn() && (
        isSuperAdmin()
        || resource.data.academyId == myAcademyId()
      );
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && isCreatingForMyAcademy();
      allow update, delete: if isAdminOfMyAcademy();
    }

    // ── 공지사항 ─────────────────────────────────────────────
    // 학생도 자기 학원 공지만 read
    match /notices/{noticeId} {
      allow read: if isSignedIn() && (isSuperAdmin() || resource.data.academyId == myAcademyId());
      allow create: if isAdminCreatingForMyAcademy();
      allow update, delete: if isAdminOfMyAcademy();
    }

    // ── 숙제 파일 ────────────────────────────────────────────
    match /hwFiles/{fileId} {
      allow read: if isSignedIn() && (isSuperAdmin() || resource.data.academyId == myAcademyId());
      allow create: if isAdminCreatingForMyAcademy();
      allow update, delete: if isAdminOfMyAcademy();
    }

    // ── 사용자 알림 ──────────────────────────────────────────
    // 학생: 자기 알림만 (uid 기반)
    // 관리자: 자기 학원 알림만
    match /userNotifications/{notifId} {
      allow read: if isOwner(resource.data.uid) || isAdminOfMyAcademy();
      allow create: if isAdminCreatingForMyAcademy();
      allow update: if isOwner(resource.data.uid);
      allow delete: if isAdminOfMyAcademy();
    }

    // ── FCM 토큰 ─────────────────────────────────────────────
    match /fcmTokens/{userId} {
      allow read: if isAdmin();
      allow write: if isOwner(userId);
    }

    // ── 결제 (관리자 전용) ───────────────────────────────────
    match /payments/{paymentId} {
      allow read, update, delete: if isAdminOfMyAcademy();
      allow create: if isAdminCreatingForMyAcademy();
    }

    // ── 레거시 컬렉션 제거됨 (Phase 6F):
    //   savedPushList — 코드 사용처 없음 (잔재)
    //   books / books/{id}/units — 시험지 출력 제거 후 미사용
    //   folders / units (top-level) — 시험지 출력 제거 후 미사용
    //   tests (레거시 시험) — Phase 6F 에서 코드/규칙 제거
    // 위 컬렉션 접근 시 기본 deny (Rules 미정의)

    // ── 푸시 알림 목록 (관리자 전용) ─────────────────────
    match /pushNotifications/{pushId} {
      allow read, update, delete: if isAdminOfMyAcademy();
      allow create: if isAdminCreatingForMyAcademy();
    }

    // ── Generator (관리자 전용 — 자기 학원만) ──────────────
    match /genBooks/{id} {
      allow read, update, delete: if isAdminOfMyAcademy();
      allow create: if isAdminCreatingForMyAcademy();
    }
    match /genChapters/{id} {
      allow read, update, delete: if isAdminOfMyAcademy();
      allow create: if isAdminCreatingForMyAcademy();
    }
    match /genPages/{id} {
      allow read, update, delete: if isAdminOfMyAcademy();
      allow create: if isAdminCreatingForMyAcademy();
    }

    // ── AI 문제 세트 (관리자 전용) ────────────────────────
    match /genQuestionSets/{id} {
      allow read, update, delete: if isAdminOfMyAcademy();
      allow create: if isAdminCreatingForMyAcademy();
    }

    // ── AI 정리 프리셋 (관리자 전용) ──────────────────────
    match /genCleanupPresets/{id} {
      allow read, update, delete: if isAdminOfMyAcademy();
      allow create: if isAdminCreatingForMyAcademy();
    }

    // ── API 호출 카운터 (학원별 일별 집계) ─────────────────
    // doc id = `{academyId}_{YYYY-MM-DD}`, body 에 academyId 필드
    // read: 자기 학원 관리자만 (super_admin 은 모든 학원)
    //       비존재 문서는 첫 호출 전 상태이므로 통과 — 클라가 0 으로 처리
    // create/update: 로그인 사용자 (자기 학원으로만 — academyId 일치)
    match /apiUsage/{id} {
      allow read: if isAdmin() && (
        isSuperAdmin() ||
        resource == null ||
        resource.data.academyId == myAcademyId()
      );
      allow create, update: if isSignedIn() && isCreatingForMyAcademy();
      allow delete: if false;
    }

    // ── AI 시험 배정 (관리자 작성, 학생 읽기) ─────────────
    // 학생도 자기 학원 시험만 read (클라가 이미 academyId 필터)
    match /genTests/{testId} {
      allow read: if isSignedIn() && (isSuperAdmin() || resource.data.academyId == myAcademyId());
      allow create: if isAdminCreatingForMyAcademy();
      allow update, delete: if isAdminOfMyAcademy();

      // 학생별 응시 완료 기록 — uid 기반 격리 (자기 응시 기록만)
      match /userCompleted/{userId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId);
        allow delete: if isAdmin();
      }
    }

    // ────────────────────────────────────────────────────────
    //   멀티테넌시 컬렉션 (Phase 0 전환)
    // ────────────────────────────────────────────────────────

    // 플랜 정의 (lite/standard/pro) — 모든 학원 공통 카탈로그
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // 학원 문서
    // read: 자기 학원만 (Phase 4-5 강화 — 자기 학원 정보만 노출)
    // write: super_admin 전용
    match /academies/{academyId} {
      allow read: if isSuperAdmin() || (isSignedIn() && academyId == myAcademyId());
      allow write: if isSuperAdmin();
    }

    // username → (uid, email) 매핑 (로그인 전 조회 필수)
    // read: 전체 공개 (정확한 username ID 알아야 접근)
    // create/update/delete: 관리자 (server API 가 Admin SDK 로 처리)
    match /usernameLookup/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 글로벌 앱 설정 (super_admin 편집)
    // 현재 항목: aiPrompts (AI Generator 시스템 프롬프트), cleanupPresets (AI OCR 정리 프리셋)
    // read: 로그인 사용자 누구나 (학원장 앱이 default 표시·시드용으로 읽음)
    // write: super_admin 전용
    match /appConfig/{configId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
